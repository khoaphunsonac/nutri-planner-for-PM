{
  "version": 2,
  "functions": {
    "api/index.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    {
      "src": "/(build|assets|css|js|images|storage|uploads)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}